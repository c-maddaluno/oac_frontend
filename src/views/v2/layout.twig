<!DOCTYPE html>
<html lang="{{ currentLang|default('it') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>{{ title|default('HD-LSD') }}</title>

    <link rel="stylesheet" href="/frontend/css/bootstrap.min.css">
    <link rel="stylesheet" href="/frontend/css/font-awesome-all.min.css">
    <link rel="stylesheet" href="/frontend/v2/css/v2.css">

    <script src="/frontend/js/lib/axios.min.js"></script>
    <script src="/frontend/js/lib/vue.global.js"></script>
    <script src="/frontend/js/lib/bootstrap.bundle.min.js"></script>

    {% block extendHead %}{% endblock %}
</head>

<body class="layout-v2"
      data-active-menu="{{ activeMenu|default('') }}"
      data-active-sidebar="{{ activeSidebar|default('') }}"
      data-active-sidebar-item="{{ activeSidebarItem|default('') }}">

    <a class="skip-link" href="#main-content">
        {{ t('common.skip_to_content')|default('Salta al contenuto principale') }}
    </a>

    {% include 'v2/partials/header.twig' %}

    <div class="layout-body">
        {% if activeSidebar %}
            <aside class="sidebar" aria-label="{{ t('common.sidebar_menu')|default('Menu laterale') }}">
                {% include 'v2/sidebars/' ~ activeSidebar ~ '.twig' %}
            </aside>
        {% endif %}

        <main id="main-content" class="main-content" tabindex="-1">
            {% block content %}{% endblock %}
        </main>
    </div>

    {% include 'v2/partials/footer.twig' %}
    {% include 'v2/partials/cookie-banner.twig' %}

    <div id="legal-app">
    <!-- TEST PRIMA LEGAL MODAL -->
        {% include 'v2/partials/legal-modal.twig' %}
        <!-- TEST DOPO LEGAL MODAL -->
    </div>

    <div id="legalModal"
     class="legal-modal"
     role="dialog"
     aria-modal="true"
     aria-labelledby="legal-modal-title"
     aria-describedby="legal-modal-description"
     tabindex="-1"
     style="display:none;">

  <div class="legal-modal-overlay"
       aria-hidden="true"
       onclick="closeLegalModal()">
  </div>

  <div class="legal-modal-content" role="document">

    <button type="button"
            class="legal-close"
            onclick="closeLegalModal()"
            aria-label="{{ t('common.close')|default('Chiudi') }}">
      <span aria-hidden="true">×</span>
    </button>

    <h2 id="legal-modal-title" class="visually-hidden">
      {{ t('legal.title')|default('Informazioni legali') }}
    </h2>

    <p id="legal-modal-description" class="visually-hidden">
      {{ t('legal.description')|default('Finestra informativa con privacy policy e cookie policy.') }}
    </p>

    <div class="legal-modal-scroll">

      <div id="legal-privacy"
           class="legal-section"
           style="display:none;">
        {% include 'v2/partials/privacy-content.twig' %}
      </div>

      <div id="legal-cookie"
           class="legal-section"
           style="display:none;">
        {% include 'v2/partials/cookie-content.twig' %}
      </div>

      <div id="legal-accessibility"
          class="legal-section"
          style="display:none;">
        {% include 'v2/partials/accessibility-content.twig' %}
      </div>

    </div>

  </div>
</div>

    <script src="/frontend/v2/js/cookie-consent.js"></script>
    <script src="/frontend/v2/js/legal-modal.js"></script>
    <script src="/frontend/v2/js/v2.js"></script>

</body>
</html>